# Copy to .env and fill in your keys:
#   cp .env.example .env
GEMINI_API_KEY=your-gemini-api-key-here
GITHUB_PAT=your-github-personal-access-token-here
# Set to true to skip Gemini and use local scanners only (avoids 429 quota errors)
GEMINI_LOCAL_ONLY=false
# Graph endpoints use tree-sitter AST parsing by default. Set true to use Gemini agents instead.
GRAPH_USE_GEMINI=false
